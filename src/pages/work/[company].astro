---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  return workEntries.map(entry => ({
    params: { company: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Clean up image path if it exists in frontmatter
const imageUrl = entry.data.image ? entry.data.image.replace('../../../public', '') : null;
---

<Layout title={`${entry.data.title} | My Work`}>
  <!-- Subtle background texture -->
  <div class="relative w-full min-h-screen overflow-hidden">
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-wabi-secondary/5 dark:from-tokyo-secondary/10 via-transparent to-transparent"></div>

    <div class="container mx-auto px-6 py-24 relative z-10">

      <!-- Back button -->
      <div class="mb-12">
        <a href="/work" class="inline-flex items-center text-sm font-medium text-wabi-secondary dark:text-tokyo-secondary hover:text-wabi-accent dark:hover:text-tokyo-accent transition-colors">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Work
        </a>
      </div>

      <!-- Header Section -->
      <header class="mb-16 border-b border-wabi-secondary/20 dark:border-tokyo-secondary/20 pb-12 flex flex-col items-center">

        {imageUrl && (
          <div class="w-32 h-32 md:w-40 md:h-40 shrink-0 rounded-3xl bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 shadow-md flex items-center justify-center overflow-hidden transition-transform duration-300 hover:scale-105 mb-8">
            <img src={imageUrl} alt={`${entry.data.title} Logo`} class="w-full h-full object-cover">
          </div>
        )}

        <div class="max-w-4xl mx-auto text-center w-full">
          {entry.data.role && (
             <p class="text-wabi-accent dark:text-tokyo-accent font-semibold tracking-wide uppercase mb-3 text-sm">
                {entry.data.role}
             </p>
          )}
          <h1 class="text-4xl md:text-6xl font-bold text-wabi-text dark:text-tokyo-text mb-6" transition:name={`title-${entry.slug}`}>
            {entry.data.title}
          </h1>

          <div class="flex flex-col items-center gap-6 mt-6">
            <p class="text-xl text-wabi-secondary dark:text-tokyo-secondary font-medium" transition:name={`date-${entry.slug}`}>
              {entry.data.date}
            </p>

            {entry.data.tags && (
              <div class="flex flex-wrap justify-center gap-3 max-w-3xl">
                {entry.data.tags.map((tag: string) => (
                  <span class="px-4 py-2 text-sm font-medium rounded-full bg-wabi-secondary/10 text-wabi-text dark:bg-tokyo-secondary/10 dark:text-tokyo-text border border-wabi-secondary/20 dark:border-tokyo-secondary/20 hover:border-wabi-accent dark:hover:border-tokyo-accent hover:text-wabi-accent dark:hover:text-tokyo-accent hover:bg-wabi-accent/10 dark:hover:bg-tokyo-accent/10 transition-all duration-300 cursor-default shadow-sm hover:shadow-md transform hover:-translate-y-0.5">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>
      </header>

      <!-- Main Content -->
      <div class="max-w-4xl mx-auto">
        <article class="prose prose-lg dark:prose-invert max-w-none
          prose-p:leading-relaxed
          prose-headings:font-bold
          prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4
          prose-ul:list-none prose-ul:p-0 prose-ul:space-y-3
          prose-li:flex prose-li:items-start prose-li:gap-3
          prose-li:before:content-[''] prose-li:before:w-2 prose-li:before:h-2 prose-li:before:bg-wabi-accent dark:prose-li:before:bg-tokyo-accent prose-li:before:rounded-full prose-li:before:mt-[0.6em] prose-li:before:flex-shrink-0
          prose-blockquote:font-normal prose-blockquote:not-italic
          prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:rounded-r-lg
          prose-blockquote:border-l-4 prose-blockquote:border-wabi-accent dark:prose-blockquote:border-tokyo-accent
          prose-blockquote:bg-wabi-secondary/5 dark:prose-blockquote:bg-tokyo-secondary/5
          prose-blockquote:text-wabi-secondary dark:prose-blockquote:text-tokyo-secondary
          prose-hr:my-12 prose-hr:border-wabi-secondary/20 dark:prose-hr:border-tokyo-secondary/20
        ">
          <Content />
        </article>
      </div>

    </div>
  </div>
</Layout>
