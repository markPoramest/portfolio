---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const workEntries = await getCollection('work');
// Sort entries by slug in descending order (company_3, company_2, company_1)
workEntries.sort((a, b) => b.slug.localeCompare(a.slug));
---

<Layout title="My Work | Your Name">
  <!-- Subtle background texture -->
  <div class="relative w-full min-h-screen overflow-hidden">
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-wabi-secondary/5 dark:from-tokyo-secondary/10 via-transparent to-transparent"></div>

    <div class="container mx-auto px-6 py-24 relative z-10">
      <div class="text-center mb-20 animate-on-scroll">
        <h1 class="text-5xl font-bold text-wabi-text dark:text-tokyo-text inline-block relative">
          My Professional Journey
          <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-24 h-1 bg-wabi-accent dark:bg-tokyo-accent rounded-full"></span>
        </h1>
        <p class="mt-8 text-wabi-secondary dark:text-tokyo-secondary max-w-2xl mx-auto">
          A curated collection of my professional roles. Click on any entry to learn more about my contributions and achievements.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-12">
        {workEntries.map((entry, index) => (
          <a href={`/work/${entry.slug}`} class="group block bg-wabi-bg dark:bg-white/5 border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-xl p-8 hover:border-wabi-accent dark:hover:border-tokyo-accent transition-all duration-300 hover:scale-[1.02] shadow-sm hover:shadow-xl dark:shadow-none relative overflow-hidden animate-on-scroll" style={`transition-delay: ${index * 100}ms;`}>
            <div class="absolute top-0 right-0 w-24 h-24 bg-wabi-accent/5 dark:bg-tokyo-accent/10 rounded-bl-full -mr-12 -mt-12 transition-transform group-hover:scale-150"></div>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-4">
              <h2 class="text-2xl font-bold text-wabi-text dark:text-tokyo-text group-hover:text-wabi-accent dark:group-hover:text-tokyo-accent transition-colors relative z-10">{entry.data.title}</h2>
              <p class="text-wabi-secondary dark:text-tokyo-secondary mt-2 md:mt-0 relative z-10 flex-shrink-0">{entry.data.date}</p>
            </div>
            {entry.data.description && (
              <p class="text-wabi-secondary dark:text-tokyo-secondary leading-relaxed mb-6 relative z-10">
                {entry.data.description}
              </p>
            )}
            <div class="relative z-10">
              <p class="text-sm font-medium text-wabi-accent dark:text-tokyo-accent flex items-center gap-2">
                View Details
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
