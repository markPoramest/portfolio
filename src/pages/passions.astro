---
import Layout from '../layouts/Layout.astro';

// Data for visited prefectures, grouped by region
const visitedPrefecturesByRegion = {
  "Kanto": ["Tokyo", "Kanagawa", "Saitama", "Chiba", "Ibaraki", "Tochigi", "Gunma"],
  "Chubu": ["Aichi", "Gifu", "Shizuoka", "Yamanashi", "Nagano", "Niigata", "Toyama", "Ishikawa", "Fukui"],
  "Kansai": ["Osaka", "Kyoto", "Hyogo", "Nara", "Wakayama"],
  "Chugoku": ["Hiroshima", "Okayama", "Yamaguchi"],
  "Kyushu": ["Fukuoka", "Saga", "Nagasaki", "Kumamoto", "Oita"]
};

const jpopArtists = ["Yuuri", "Mrs. GREEN APPLE", "Back Number", "Official Hige Dandism"];
const animeList = ["Kimetsu no Yaiba", "Jujutsu Kaisen", "Attack on Titan", "DAN DA DAN"];

const profileCarouselImages = [
  "/portfolio/image/japan-carousel/001.jpg",
  "/portfolio/image/japan-carousel/002.jpg",
  "/portfolio/image/japan-carousel/003.jpg",
  "/portfolio/image/japan-carousel/004.jpg",
  "/portfolio/image/japan-carousel/005.jpg",
];
---

<Layout title="My Passion for Japan">
  <div class="relative min-h-screen w-full overflow-hidden">
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_right,_var(--tw-gradient-stops))] from-wabi-secondary/5 dark:from-tokyo-secondary/10 via-transparent to-transparent"></div>

    <div class="container mx-auto px-6 py-24 relative z-10">

      <!-- Profile Auto Carousel and Header Section -->
      <div class="flex flex-col items-center mb-20">
        <!-- Infinite Scrolling Marquee Container -->
        <div class="relative w-full max-w-8xl h-64 md:h-72 overflow-hidden mb-8 group marquee-mask" id="profile-marquee">

          <div class="flex w-max h-full animate-marquee group-hover:[animation-play-state:paused]">
            <!-- Render images twice for seamless loop -->
            {[...profileCarouselImages, ...profileCarouselImages].map((img, index) => (
              <div class="flex-shrink-0 w-64 md:w-80 h-full mx-4">
                <img
                  src={img}
                  alt={`Profile in Japan ${index + 1}`}
                  class="w-full h-full object-cover rounded-2xl shadow-xl border-2 border-wabi-secondary/10 dark:border-tokyo-secondary/10"
                />
              </div>
            ))}
          </div>
        </div>

        <div class="text-center">
          <h1 class="text-4xl md:text-6xl font-bold text-wabi-text dark:text-tokyo-text tracking-tight mb-6">
            Beyond the Code: <br class="md:hidden" />
            <span class="text-wabi-accent dark:text-tokyo-accent">My Love for Japan</span>
          </h1>
          <p class="text-lg md:text-xl text-wabi-secondary dark:text-tokyo-secondary max-w-3xl mx-auto leading-relaxed">
            A glimpse into the culture, language, and experiences that continually inspire my life and work.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 auto-rows-auto">

        <!-- Language Learning -->
        <div class="lg:col-span-1 group relative bg-wabi-bg dark:bg-tokyo-bg p-8 rounded-2xl border border-wabi-secondary/20 dark:border-tokyo-secondary/20 shadow-lg flex flex-col justify-between animate-on-scroll">
          <div class="absolute top-0 right-0 p-6 opacity-10 group-hover:opacity-20 transition-opacity duration-500 group-hover:scale-110 transform">
            <span class="text-9xl font-bold text-wabi-text dark:text-tokyo-text pointer-events-none">学</span>
          </div>
          <div class="relative z-10 mb-8">
            <h2 class="text-3xl font-bold text-wabi-text dark:text-tokyo-text mb-4">Language</h2>
            <p class="text-wabi-secondary dark:text-tokyo-secondary text-lg">
              I've dedicated years to mastering the Japanese language, providing a challenging yet rewarding mental workout.
            </p>
          </div>
          <div class="relative z-10 mt-auto">
            <button id="openCertModal" class="inline-flex items-center gap-2 px-6 py-3 bg-wabi-accent text-wabi-bg dark:bg-tokyo-accent dark:text-tokyo-bg rounded-full font-bold text-lg shadow-md hover:opacity-90 transition-opacity focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-wabi-bg dark:focus:ring-offset-tokyo-bg focus:ring-wabi-accent dark:focus:ring-tokyo-accent cursor-pointer">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path></svg>
              JLPT N2 Certified
            </button>
          </div>
        </div>

        <!-- Japanese Culture -->
        <div class="lg:col-span-2 group relative bg-gradient-to-br from-wabi-bg to-wabi-secondary/5 dark:from-tokyo-bg dark:to-tokyo-secondary/10 p-8 rounded-2xl border border-wabi-secondary/20 dark:border-tokyo-secondary/20 shadow-lg flex flex-col justify-center animate-on-scroll" style="transition-delay: 100ms;">
          <h2 class="text-3xl font-bold text-wabi-text dark:text-tokyo-text mb-6">Culture & Media</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="bg-wabi-bg/50 dark:bg-tokyo-bg/50 p-6 rounded-xl border border-wabi-secondary/10 dark:border-tokyo-secondary/10 shadow-sm">
               <h3 class="text-xl font-bold text-wabi-accent dark:text-tokyo-accent mb-4 flex items-center gap-2">
                 <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"></path></svg>
                 Favorite J-Pop Artists
               </h3>
               <ul class="space-y-3">
                 {jpopArtists.map(artist => <li class="flex items-center gap-3 text-wabi-text dark:text-tokyo-text font-medium text-lg"><span class="w-2 h-2 bg-wabi-secondary dark:bg-tokyo-secondary rounded-full"></span> {artist}</li>)}
               </ul>
            </div>
            <div class="bg-wabi-bg/50 dark:bg-tokyo-bg/50 p-6 rounded-xl border border-wabi-secondary/10 dark:border-tokyo-secondary/10 shadow-sm">
               <h3 class="text-xl font-bold text-wabi-accent dark:text-tokyo-accent mb-4 flex items-center gap-2">
                 <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"></path></svg>
                 Favorite Anime
               </h3>
               <ul class="space-y-3">
                 {animeList.map(anime => <li class="flex items-center gap-3 text-wabi-text dark:text-tokyo-text font-medium text-lg"><span class="w-2 h-2 bg-wabi-secondary dark:bg-tokyo-secondary rounded-full"></span> {anime}</li>)}
               </ul>
            </div>
          </div>
        </div>

        <!-- Travel Footprint -->
        <div class="lg:col-span-3 group relative bg-wabi-bg dark:bg-tokyo-bg p-8 rounded-2xl border border-wabi-secondary/20 dark:border-tokyo-secondary/20 shadow-lg flex flex-col justify-center text-left animate-on-scroll" style="transition-delay: 200ms;">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-16 h-16 bg-wabi-accent/10 dark:bg-tokyo-accent/10 text-wabi-accent dark:text-tokyo-accent rounded-full flex items-center justify-center text-3xl font-black shadow-inner border border-wabi-accent/20 dark:border-tokyo-accent/20">
              10
            </div>
            <h2 class="text-3xl font-bold text-wabi-text dark:text-tokyo-text">Trips to Japan</h2>
          </div>
          <p class="text-wabi-secondary dark:text-tokyo-secondary text-lg mb-8 leading-relaxed max-w-3xl">
            My travels have taken me through <strong class="text-wabi-accent dark:text-tokyo-accent font-bold">29 of 47</strong> prefectures. Below are the regions I've explored.
          </p>

          <!-- Equal Column Grid for Regions -->
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 w-full">
            {Object.entries(visitedPrefecturesByRegion).map(([region, prefs]) => (
              <div class="flex flex-col">
                <h4 class="text-lg font-bold text-wabi-text dark:text-tokyo-text border-b-2 border-wabi-accent/20 dark:border-tokyo-accent/20 pb-2 mb-4 w-full">{region}</h4>
                <ul class="flex flex-col space-y-2">
                  {prefs.map(pref => (
                    <li class="flex items-center gap-2 text-wabi-secondary dark:text-tokyo-secondary">
                      <svg class="w-4 h-4 text-wabi-accent dark:text-tokyo-accent shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path></svg>
                      {pref}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>

        <!-- Mark no Nihon Tabi -->
        <div class="lg:col-span-3 group relative bg-gradient-to-br from-wabi-bg to-wabi-secondary/5 dark:from-tokyo-bg dark:to-tokyo-secondary/10 p-8 md:p-12 rounded-2xl border border-wabi-secondary/20 dark:border-tokyo-secondary/20 shadow-lg flex flex-col md:flex-row items-center gap-12 animate-on-scroll" style="transition-delay: 300ms;">

          <!-- Left Column: Logo Frame and Text -->
          <div class="md:w-1/2 flex flex-col sm:flex-row items-center text-center sm:text-left gap-8">

            <!-- Logo Frame -->
            <div class="w-32 h-32 md:w-36 md:h-36 shrink-0 rounded-3xl bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 shadow-md flex items-center justify-center overflow-hidden transition-transform duration-300 hover:scale-105">
              <img src="/portfolio/image/mark-no-nihon-tabi-logo.jpg" alt="Mark no Nihon Tabi Logo" class="w-full h-full object-cover">
            </div>

            <div>
              <h2 class="text-3xl md:text-4xl font-bold text-wabi-text dark:text-tokyo-text mb-4">Mark no Nihon Tabi</h2>
              <p class="text-md md:text-lg text-wabi-secondary dark:text-tokyo-secondary leading-relaxed">
                Discover my recommended tourist spots, hidden gems, and comprehensive travel guides. Follow my journey across Japan on social media!
              </p>
            </div>
          </div>

          <!-- Right Column: Social Links -->
          <div class="md:w-1/2 w-full">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-6">
              <!-- Facebook -->
              <a href="https://www.facebook.com/marknonihontabi" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center p-6 bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-xl hover:border-[#1877F2] dark:hover:border-[#1877F2] hover:shadow-lg transition-all duration-300 group/link">
                <svg class="w-10 h-10 text-[#1877F2] mb-3 group-hover/link:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                <span class="font-bold text-wabi-text dark:text-tokyo-text">Facebook</span>
              </a>

              <!-- YouTube -->
              <a href="https://youtube.com/@marknonihontabi" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center p-6 bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-xl hover:border-[#FF0000] dark:hover:border-[#FF0000] hover:shadow-lg transition-all duration-300 group/link">
                <svg class="w-10 h-10 text-[#FF0000] mb-3 group-hover/link:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                <span class="font-bold text-wabi-text dark:text-tokyo-text">YouTube</span>
              </a>

              <!-- TikTok -->
              <a href="https://www.tiktok.com/@marknonihontabi" target="_blank" rel="noopener noreferrer" class="flex flex-col items-center justify-center p-6 bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-xl hover:border-wabi-text dark:hover:border-white hover:shadow-lg transition-all duration-300 group/link">
                <svg class="w-10 h-10 text-wabi-text dark:text-tokyo-text mb-3 group-hover/link:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
                <span class="font-bold text-wabi-text dark:text-tokyo-text">TikTok</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- JLPT Certificate Modal -->
  <div id="certModal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/70 backdrop-blur-sm transition-opacity duration-300 opacity-0">
    <div id="modalContent" class="bg-wabi-bg dark:bg-tokyo-bg rounded-2xl shadow-2xl w-full max-w-3xl mx-4 p-4 relative transform scale-95 transition-all duration-300">
      <button id="closeCertModal" class="absolute -top-4 -right-4 w-10 h-10 bg-wabi-accent text-wabi-bg rounded-full flex items-center justify-center shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-wabi-accent hover:opacity-90 z-10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
      <div class="w-full h-full min-h-[400px] flex items-center justify-center bg-wabi-secondary/10 dark:bg-tokyo-secondary/10 rounded-lg overflow-hidden">
         <!-- Replace this img src with your actual certificate image path -->
         <img src="/portfolio/cert/jlpt-n2.jpg" alt="JLPT N2 Certificate" class="max-w-full max-h-[80vh] object-contain">
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // Certificate Modal Logic
    const certModal = document.getElementById('certModal');
    const modalContent = document.getElementById('modalContent');
    const openBtn = document.getElementById('openCertModal');
    const closeBtn = document.getElementById('closeCertModal');

    const showModal = () => {
      if (!certModal || !modalContent) return;
      certModal.classList.remove('hidden');
      setTimeout(() => {
        certModal.classList.remove('opacity-0');
        modalContent.classList.remove('scale-95');
      }, 10);
      document.body.style.overflow = 'hidden';
    };

    const hideModal = () => {
      if (!certModal || !modalContent) return;
      certModal.classList.add('opacity-0');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        certModal.classList.add('hidden');
        document.body.style.overflow = '';
      }, 300);
    };

    if (certModal && openBtn && closeBtn) {
      openBtn.addEventListener('click', showModal);
      closeBtn.addEventListener('click', hideModal);

      certModal.addEventListener('click', (e) => {
        if (e.target === certModal) {
          hideModal();
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !certModal.classList.contains('hidden')) {
          hideModal();
        }
      });
    }
  });
</script>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  .animate-marquee {
    /* The animation duration is calculated based on the number of images to keep the speed consistent */
    /* 5 images * 8s per image = 40s total duration */
    animation: marquee 30s linear infinite;
  }

  .marquee-mask {
    -webkit-mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
    mask-image: linear-gradient(to right, transparent, black 20%, black 80%, transparent);
  }
</style>
