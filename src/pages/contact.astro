---
import Layout from '../layouts/Layout.astro';

const socialLinks = [
  {
    href: "https://github.com/markPoramest",
    name: "GitHub",
    description: "Code, projects, and contributions.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`
  },
  {
    href: "https://www.linkedin.com/in/poramest-vichitnopawan-8745851a1",
    name: "LinkedIn",
    description: "Professional network and career.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>`
  },
  {
    href: "https://medium.com/@TridentMark",
    name: "Medium",
    description: "Thoughts, articles, and tutorials.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor"><path d="M7.444 24h9.111c.411 0 .744-.333.744-.744v-1.856c0-.411-.333-.744-.744-.744h-9.111c-.411 0-.744.333-.744.744v1.856c0 .411.333.744.744.744zm6.296-5.185h5.926c.411 0 .744-.333.744-.744v-1.856c0-.411-.333-.744-.744-.744h-5.926c-.411 0-.744.333-.744.744v1.856c0 .411.333.744.744.744zm-13.74-14.074v15.259c0 .411.333.744.744.744h3.704c.411 0 .744-.333.744-.744v-15.259c0-.411-.333-.744-.744-.744h-3.704c-.411 0-.744.333-.744.744zm15.556 5.926h5.926c.411 0 .744-.333.744-.744v-1.856c0-.411-.333-.744-.744-.744h-5.926c-.411 0-.744.333-.744.744v1.856c0 .411.333.744.744.744z"/></svg>`
  }
];
---

<Layout title="Contact | Your Name">
  <div class="relative min-h-screen w-full overflow-hidden">
    <div class="absolute inset-0 pointer-events-none bg-[radial-gradient(circle_at_top_left,_var(--tw-gradient-stops))] from-wabi-secondary/5 dark:from-tokyo-secondary/10 via-transparent to-transparent"></div>

    <div class="container mx-auto px-6 py-24 relative z-10">
      <div class="text-center mb-16 animate-on-scroll">
        <h1 class="text-4xl md:text-5xl font-bold text-wabi-text dark:text-tokyo-text tracking-tight">Get In Touch</h1>
        <p class="text-lg text-wabi-secondary dark:text-tokyo-secondary mt-4 max-w-2xl mx-auto">
          I'm open to new opportunities! Feel free to reach out if you think my profile is a good fit for your team.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Contact Form -->
        <div class="bg-wabi-bg/50 dark:bg-tokyo-bg/50 p-8 rounded-lg shadow-lg border border-wabi-secondary/10 dark:border-tokyo-secondary/10 animate-on-scroll" style="transition-delay: 100ms;">
          <h2 class="text-2xl font-bold mb-6 text-wabi-text dark:text-tokyo-text">Send a Message</h2>
          <form id="contactForm" action="https://formsubmit.co/2411kjn@gmail.com" method="POST">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_replyto">

            <div class="mb-4">
              <label for="name" class="block text-wabi-secondary dark:text-tokyo-secondary mb-2">Name</label>
              <input type="text" id="name" name="name" class="w-full px-4 py-2 bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-md focus:ring-2 focus:ring-wabi-accent dark:focus:ring-tokyo-accent focus:outline-none transition-shadow" required>
            </div>
            <div class="mb-4">
              <label for="email" class="block text-wabi-secondary dark:text-tokyo-secondary mb-2">Email</label>
              <input type="email" id="email" name="email" class="w-full px-4 py-2 bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-md focus:ring-2 focus:ring-wabi-accent dark:focus:ring-tokyo-accent focus:outline-none transition-shadow" required>
            </div>
            <div class="mb-6">
              <label for="message" class="block text-wabi-secondary dark:text-tokyo-secondary mb-2">Message</label>
              <textarea id="message" name="message" rows="5" class="w-full px-4 py-2 bg-wabi-bg dark:bg-tokyo-bg border border-wabi-secondary/20 dark:border-tokyo-secondary/20 rounded-md focus:ring-2 focus:ring-wabi-accent dark:focus:ring-tokyo-accent focus:outline-none transition-shadow" required></textarea>
            </div>
            <button type="submit" id="submitBtn" class="w-full bg-wabi-accent text-wabi-bg dark:bg-tokyo-accent dark:text-tokyo-bg font-bold py-3 px-4 rounded-lg hover:opacity-90 transition-all flex justify-center items-center h-12">
              <span>Send Message</span>
            </button>
          </form>
        </div>

        <!-- Social Links -->
        <div class="space-y-6 animate-on-scroll" style="transition-delay: 200ms;">
          {socialLinks.map(link => (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-6 bg-wabi-bg/50 dark:bg-tokyo-bg/50 p-6 rounded-lg shadow-lg border border-wabi-secondary/10 dark:border-tokyo-secondary/10 hover:shadow-xl hover:border-wabi-accent/50 dark:hover:border-tokyo-accent/50 transition-all duration-300">
              <div class="text-wabi-accent dark:text-tokyo-accent group-hover:scale-110 transition-transform">
                <Fragment set:html={link.icon} />
              </div>
              <div>
                <h3 class="text-xl font-bold text-wabi-text dark:text-tokyo-text">{link.name}</h3>
                <p class="text-wabi-secondary dark:text-tokyo-secondary">{link.description}</p>
              </div>
            </a>
          ))}
        </div>

      </div>
    </div>
  </div>

  <!-- Success Modal -->
  <div id="successModal" class="fixed inset-0 z-50 flex items-center justify-center hidden bg-black/50 backdrop-blur-sm transition-opacity duration-300 opacity-0">
    <div id="modalContent" class="bg-wabi-bg dark:bg-tokyo-bg p-8 rounded-2xl shadow-2xl border border-wabi-secondary/20 dark:border-tokyo-secondary/20 max-w-sm w-full mx-4 text-center transform scale-95 transition-all duration-300 relative">
      <div class="w-16 h-16 bg-green-100 dark:bg-green-900/30 text-green-500 dark:text-green-400 rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
      </div>
      <h3 class="text-2xl font-bold text-wabi-text dark:text-tokyo-text mb-2">Message Sent!</h3>
      <p class="text-wabi-secondary dark:text-tokyo-secondary mb-8">Thank you for reaching out. I will get back to you as soon as possible.</p>
      <button id="closeModalBtn" class="w-full bg-wabi-accent text-wabi-bg dark:bg-tokyo-accent dark:text-tokyo-bg font-bold py-3 px-4 rounded-lg hover:opacity-90 transition-opacity">
        Done
      </button>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const modal = document.getElementById('successModal');
    const modalContent = document.getElementById('modalContent');
    const closeModalBtn = document.getElementById('closeModalBtn');

    if (form && submitBtn && modal && modalContent && closeModalBtn) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault(); // Prevent default redirection

        // Show loading state
        const originalBtnHTML = submitBtn.innerHTML;
        submitBtn.innerHTML = `<svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Sending...`;
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
            headers: {
              'Accept': 'application/json' // FormSubmit returns JSON with this header instead of redirecting
            }
          });

          if (response.ok) {
            // Show modal
            modal.classList.remove('hidden');
            // Tiny delay to allow display:block to apply before animating opacity/transform
            setTimeout(() => {
              modal.classList.remove('opacity-0');
              modalContent.classList.remove('scale-95');
              modalContent.classList.add('scale-100');
            }, 10);

            form.reset();
          } else {
            alert('Oops! There was a problem submitting your form.');
          }
        } catch (error) {
          alert('Oops! Network error. Please try again later.');
        } finally {
          // Restore button state
          submitBtn.innerHTML = originalBtnHTML;
          submitBtn.disabled = false;
          submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
        }
      });

      // Hide modal function
      const hideModal = () => {
        modal.classList.add('opacity-0');
        modalContent.classList.remove('scale-100');
        modalContent.classList.add('scale-95');

        // Wait for animation to finish before hiding
        setTimeout(() => {
          modal.classList.add('hidden');
        }, 300);
      };

      // Close modal events
      closeModalBtn.addEventListener('click', hideModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) hideModal();
      });
    }
  });
</script>
