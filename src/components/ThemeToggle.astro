---
---
<button id="themeToggle" class="w-10 h-10 rounded-full flex items-center justify-center text-wabi-text dark:text-tokyo-text transition-colors duration-300 ml-4 hover:bg-wabi-secondary/10 dark:hover:bg-tokyo-secondary/10 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-wabi-accent dark:focus:ring-tokyo-accent">
  <span class="sr-only">Toggle theme</span>

  <!-- Moon Icon -->
  <svg class="light-icon hidden dark:block w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21.752 15.002A9.718 9.718 0 0115 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 10.25c0 5.385 4.365 9.75 9.75 9.75 2.135 0 4.139-.69 5.752-1.848z" />
  </svg>

  <!-- Sun Icon -->
  <svg class="dark-icon block dark:hidden w-6 h-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
  </svg>
</button>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document.addEventListener('astro:page-load', () => {
    const themeToggleBtn = document.getElementById('themeToggle');
    if (themeToggleBtn) {
       themeToggleBtn.addEventListener('click', handleToggleClick);
    }
  });
</script>
